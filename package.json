{
  "name": "world-ethglobal-nyc-starter-pack",
  "private": true,
  "version": "0.1.0",
  "description": "Starter pack for World-sponsored ETHGlobal NYC hackers.",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:claim": "pnpm --filter @world-starter/human-gated-claim dev",
    "dev:agent": "pnpm --filter @world-starter/human-agent-console dev",
    "dev:hitl": "pnpm --filter @world-starter/human-approval-desk dev",
    "dev:bench": "pnpm --filter @world-starter/ui-test-bench dev",
    "dev:all": "pnpm --parallel --filter @world-starter/human-gated-claim --filter @world-starter/human-agent-console --filter @world-starter/ui-test-bench --filter @world-starter/human-approval-desk dev",
    "start:claim": "pnpm --filter @world-starter/human-gated-claim start",
    "start:agent": "pnpm --filter @world-starter/human-agent-console start",
    "start:hitl": "pnpm --filter @world-starter/human-approval-desk start",
    "start:bench": "pnpm --filter @world-starter/ui-test-bench start",
    "start:all": "pnpm --parallel --filter @world-starter/human-gated-claim --filter @world-starter/human-agent-console --filter @world-starter/ui-test-bench --filter @world-starter/human-approval-desk start",
    "test": "pnpm -r --if-present test",
    "test:ui": "node scripts/ui-ux-smoke.mjs",
    "test:world-app-surface": "node scripts/world-app-surface-check.mjs",
    "release:external": "node scripts/release-external-checks.mjs",
    "release:record-userop": "node scripts/record-world-app-userop.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "contracts:test": "forge test -C contracts",
    "contracts:build": "forge build -C contracts"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "next": "^16.2.7",
    "playwright": "^1.57.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
